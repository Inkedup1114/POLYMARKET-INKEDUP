# InkedUp Polymarket Bot - Environment Configuration Example
# Copy this file to .env and configure with your actual values

# Application Configuration
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# Polymarket API Configuration
POLYMARKET_API_BASE=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com

# Authentication - IMPORTANT: Never commit real keys to version control
PRIVATE_KEY=your_ethereum_private_key_here
PUBLIC_KEY=your_ethereum_public_address_here

# Database Configuration
DATABASE_URL=sqlite:///bot_data.db
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600

# Redis Configuration (optional)
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SENTINEL_ENABLED=false

# Risk Management Settings
GLOBAL_RISK_CAP=1000.0
MAX_POSITION_SIZE=100.0
MAX_MARKET_EXPOSURE=250.0
MAX_OUTCOME_EXPOSURE=500.0

# Strategy Configuration
COMPLEMENT_ARB_MIN_DEVIATION=0.02
COMPLEMENT_ARB_MAX_DEVIATION=0.15
COMPLEMENT_ARB_BASE_SIZE=10.0
COMPLEMENT_ARB_MAX_SIZE=50.0
COMPLEMENT_ARB_LIQUIDITY_CHECK=true
COMPLEMENT_ARB_RISK_ADJUSTMENT=true

SPREAD_ALERT_BPS=100
SPREAD_ALERT_MIN_SIZE=100.0
SPREAD_ALERT_MAX_SIZE=1000.0

# Performance Settings
MARKET_CACHE_TTL=60
BOOK_CACHE_TTL=10
BOOK_BATCH_SIZE=20
MAX_CONCURRENT_REQUESTS=5
REQUEST_RATE_LIMIT=10.0

# Liquidity Analysis
LIQUIDITY_METHOD=composite
LIQUIDITY_TOP_N_LEVELS=5
LIQUIDITY_EFFECTIVE_SPREAD_PCT=0.01
LIQUIDITY_CACHE_TTL_SECONDS=30

# Feature Flags
FEATURE_COMPLEMENT_ARBITRAGE=true
FEATURE_SPREAD_ALERTS=true
FEATURE_MARKET_MAKING=false
FEATURE_WEBSOCKET_STREAMING=true
FEATURE_ADVANCED_RISK_MODELS=false

# Development Settings
USE_STUB_CLIENT=true
ENABLE_TEST_ENDPOINTS=true
TEST_DATA_ENABLED=true
ENABLE_DEBUG_ENDPOINTS=true

# Monitoring and Health Checks
HEALTH_CHECK_URL=http://localhost:8080/health
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=5
METRICS_ENABLED=true
METRICS_PORT=8080
ENABLE_PERFORMANCE_MONITORING=true

# Logging Configuration
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10
LOG_BACKUP_COUNT=5
LOG_FORMAT=text
ENABLE_AUDIT_LOGS=true

# Security Settings
ENABLE_CORS=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
ENABLE_RATE_LIMITING=true
RATE_LIMIT_PER_MINUTE=1000
ENABLE_IP_WHITELIST=false
TRUSTED_PROXIES=127.0.0.1

# Authentication & Authorization
JWT_SECRET_KEY=your_jwt_secret_key_here_generate_with_openssl_rand_base64_32
JWT_EXPIRATION_HOURS=24
API_KEY_REQUIRED=false
ENABLE_2FA=false

# Circuit Breaker Configuration
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60
CIRCUIT_BREAKER_HALF_OPEN_CALLS=3

# API Client Configuration
API_TIMEOUT_SECONDS=30
API_RETRY_ATTEMPTS=3
API_RETRY_MAX_DELAY_SECONDS=30
API_RETRY_EXPONENTIAL_BASE=2.0
API_RETRY_JITTER_ENABLED=true

# Notification Settings (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
MONITORING_WEBHOOK=https://your-monitoring-webhook.com/alerts
ALERT_EMAIL=alerts@yourcompany.com

# External Services (optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=1.0

# Backup Settings
BACKUP_ENABLED=false
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_ENCRYPTION_ENABLED=false
BACKUP_S3_BUCKET=your-backup-bucket

# Development Tools
JUPYTER_ENABLED=true
JUPYTER_PORT=8888
JUPYTER_TOKEN=your_jupyter_token_here

# Container Settings (for Docker deployment)
CONTAINER_NAME=inkedup-bot-dev
WORKER_THREADS=4
ASYNC_TIMEOUT=30
MEMORY_LIMIT_MB=1024

# Testing Settings
TEST_DATABASE_URL=sqlite:///test.db
TEST_REDIS_URL=redis://localhost:6379/1
PYTEST_MARKERS=unit,integration,performance
COVERAGE_MIN_PERCENTAGE=80

# Additional Development Settings
ENABLE_PROFILING=false
PROFILE_OUTPUT_DIR=profiles/
DEBUG_SQL_QUERIES=false
MOCK_EXTERNAL_APIS=false

# Legacy Configuration (for backward compatibility)
MARKET_FILTER=market1,market2  # Comma-separated market slugs (leave empty for all markets)
MIN_LIQUIDITY=1000
MIN_VOLUME_24H=5000
POSITION_RISK_CAP_USD=100
GLOBAL_RISK_CAP_USD=1000
MARKET_RISK_CAP_USD=200
PER_MARKET_RISK_CAP_USD=150
PER_OUTCOME_RISK_CAP_USD=50
SNAPSHOT_INTERVAL_SECONDS=300  # Take snapshots every 5 minutes
SNAPSHOT_RETENTION_DAYS=7      # Keep snapshots for 7 days
WS_ENABLED=false      # Enable WebSocket streaming

# Market Making Strategy (Legacy)
MM_ENABLED=false               # Enable market making strategy
MM_TARGET_SPREAD_BPS=50        # Target spread in basis points
MM_MAX_POSITION_SIZE_USD=100   # Maximum position size per market
MM_QUOTE_SIZE_USD=10           # Size of each quote
MM_MIN_SPREAD_BPS=20           # Minimum spread to maintain
MM_MAX_SPREAD_BPS=200          # Maximum spread to quote
MM_INVENTORY_SKEW_FACTOR=0.1   # Factor for inventory skewing
MM_EDGE_BPS=5                  # Edge to add on top of fair value
MM_MIN_LIQUIDITY=1000          # Minimum market liquidity required
MM_ENABLED_MARKETS=            # Comma-separated list of markets for MM (empty = all markets)

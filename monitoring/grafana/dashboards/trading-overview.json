{
  "dashboard": {
    "id": null,
    "title": "InkedUp Trading Overview",
    "tags": ["inkedup", "trading", "overview"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "Active Orders",
        "type": "stat",
        "targets": [
          {
            "expr": "inkedup_active_orders_total",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 50},
                {"color": "red", "value": 100}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Total Position Value",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(inkedup_position_value_usd)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": {
              "mode": "thresholds"
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 6, "y": 0}
      },
      {
        "id": 3,
        "title": "Risk Utilization",
        "type": "gauge",
        "targets": [
          {
            "expr": "inkedup_risk_utilization_percent",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 100,
            "unit": "percent",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 70},
                {"color": "red", "value": 90}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 12, "y": 0}
      },
      {
        "id": 4,
        "title": "Daily P&L",
        "type": "stat",
        "targets": [
          {
            "expr": "inkedup_daily_pnl_usd",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "currencyUSD",
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 0}
              ]
            }
          }
        },
        "gridPos": {"h": 8, "w": 6, "x": 18, "y": 0}
      },
      {
        "id": 5,
        "title": "Order Execution Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(inkedup_orders_executed_total[5m])",
            "legendFormat": "Orders/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 6,
        "title": "API Response Times",
        "type": "timeseries",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(inkedup_api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "95th percentile",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(inkedup_api_request_duration_seconds_bucket[5m]))",
            "legendFormat": "Median",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      },
      {
        "id": 7,
        "title": "Position Distribution by Market",
        "type": "piechart",
        "targets": [
          {
            "expr": "sum by (market) (inkedup_position_value_usd)",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 16}
      },
      {
        "id": 8,
        "title": "Arbitrage Opportunities Found",
        "type": "timeseries",
        "targets": [
          {
            "expr": "increase(inkedup_arbitrage_opportunities_found_total[1m])",
            "legendFormat": "Opportunities/min",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 16}
      },
      {
        "id": 9,
        "title": "Error Rate",
        "type": "timeseries",
        "targets": [
          {
            "expr": "rate(inkedup_errors_total[5m])",
            "legendFormat": "Errors/sec",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic",
              "fixedColor": "red"
            }
          }
        },
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 16}
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {},
    "templating": {
      "list": [
        {
          "name": "environment",
          "type": "query",
          "query": "label_values(inkedup_active_orders_total, environment)",
          "current": {
            "selected": false,
            "text": "production",
            "value": "production"
          }
        }
      ]
    },
    "annotations": {
      "list": [
        {
          "name": "Deployments",
          "datasource": "Prometheus",
          "expr": "inkedup_deployment_info",
          "titleFormat": "Deployment: {{version}}",
          "textFormat": "Version {{version}} deployed to {{environment}}"
        }
      ]
    },
    "refresh": "5s",
    "schemaVersion": 30,
    "version": 1,
    "links": [
      {
        "title": "System Health Dashboard",
        "url": "/d/system-health",
        "type": "dashboards"
      }
    ]
  }
}
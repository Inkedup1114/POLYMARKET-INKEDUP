# ===================================================================
# InkedUp Polymarket Bot - Environment Configuration Template
# ===================================================================
# This file contains all environment variables needed to configure the
# Polymarket trading bot. Copy this file to .env and fill in your values.
# ===================================================================

# ===================================================================
# POLYMARKET API CONFIGURATION
# ===================================================================
# Base URL for Polymarket CLOB API
POLYMARKET_API_BASE=https://clob.polymarket.com

# WebSocket URL for real-time market data streaming
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com

# ===================================================================
# TRADING CREDENTIALS (REQUIRED FOR LIVE TRADING)
# ===================================================================
# Your Ethereum wallet public key (address) for trading
# Format: 0x followed by 40 hexadecimal characters
PUBLIC_KEY=0x976d899C1A2e2c7efb0C94df2959e4B35d0D0b51

# Your Ethereum wallet private key for signing transactions
# WARNING: Keep this secure and never commit to version control
PRIVATE_KEY=c07213477af4c027be20bf413522bf0c9a22de9b4fff72fef7609ff6b4567cf8

# RPC URL for Polygon network (used for transaction signing)
RPC_URL=https://polygon-rpc.com

# ===================================================================
# API CLIENT SETTINGS
# ===================================================================
# Timeout for API requests in seconds
API_TIMEOUT_SECONDS=30

# Maximum number of retry attempts for failed API requests
API_RETRY_ATTEMPTS=3

# Delay between retry attempts in seconds
API_RETRY_DELAY_SECONDS=1

# ===================================================================
# DATABASE CONFIGURATION
# ===================================================================
# Database connection URL (SQLite by default)
# Examples: 
#   SQLite: sqlite:///bot_data.db
#   PostgreSQL: postgresql://user:pass@localhost/polymarket
DATABASE_URL=sqlite:///bot_data.db

# Enable SQL query logging for debugging (true/false)
DATABASE_ECHO=false

# Database connection pool size (for production databases)
DATABASE_POOL_SIZE=5

# ===================================================================
# LOGGING CONFIGURATION
# ===================================================================
# Logging level for the application
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log message format
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Optional log file path (leave empty for console-only logging)
LOG_FILE=

# Maximum log file size in bytes before rotation (default: 10MB)
LOG_MAX_BYTES=10485760

# Number of backup log files to keep
LOG_BACKUP_COUNT=5

# ===================================================================
# MARKET FILTERING & THRESHOLDS
# ===================================================================
# Comma-separated list of market slugs to trade (leave empty for all markets)
# Example: "will-trump-win-2024,will-bitcoin-hit-100k-2024"
MARKET_FILTER=

# Minimum liquidity threshold in USD for markets to be considered
# Markets with less than this liquidity will be filtered out
MIN_LIQUIDITY=1000

# Minimum 24-hour trading volume in USD for markets to be considered
# Markets with less than this volume will be filtered out
MIN_VOLUME_24H=5000

# Minimum spread threshold in basis points for market filtering
MIN_SPREAD_BPS=0

# Maximum spread threshold in basis points for market filtering
MAX_SPREAD_BPS=10000

# Alert threshold for spread monitoring (in basis points, 100 = 1%)
# Bot will alert when spreads exceed this value
SPREAD_ALERT_BPS=100

# ===================================================================
# RISK MANAGEMENT CONFIGURATION
# ===================================================================
# Maximum risk exposure per individual position (in USD)
POSITION_RISK_CAP_USD=100

# Maximum total risk exposure across all positions (in USD)
GLOBAL_RISK_CAP_USD=1000

# Maximum risk exposure per market (in USD)
MARKET_RISK_CAP_USD=200

# Maximum risk exposure per individual market (alternative to MARKET_RISK_CAP_USD)
PER_MARKET_RISK_CAP_USD=150

# Maximum risk exposure per outcome type (YES/NO) within a market (in USD)
PER_OUTCOME_RISK_CAP_USD=50

# Maximum position size for any single trade (in USD)
MAX_POSITION_SIZE_USD=1000

# Maximum order size for any single order (in USD)
MAX_ORDER_SIZE_USD=100

# ===================================================================
# SCANNER CONFIGURATION
# ===================================================================
# Cache TTL for market data in seconds (default: 300 = 5 minutes)
MARKET_CACHE_TTL=300

# Number of order books to fetch in a single batch request
BOOK_BATCH_SIZE=120

# Interval between market scans in seconds
SCAN_INTERVAL_SECONDS=30

# Maximum number of markets to display per scan
MAX_MARKETS_PER_SCAN=15

# ===================================================================
# WEBSOCKET CONFIGURATION
# ===================================================================
# Enable WebSocket streaming for real-time market data
# Set to true for production, false for testing or when API limits are a concern
WS_ENABLED=false

# Maximum number of WebSocket reconnection attempts
WS_RECONNECT_ATTEMPTS=5

# Delay between WebSocket reconnection attempts in seconds
WS_RECONNECT_DELAY_SECONDS=5

# ===================================================================
# ORDER EXECUTION PARAMETERS
# ===================================================================
# Default order type (GTC, IOC, FOK)
DEFAULT_ORDER_TYPE=GTC

# Timeout for order execution in seconds
ORDER_TIMEOUT_SECONDS=30

# Maximum slippage tolerance in basis points
SLIPPAGE_TOLERANCE_BPS=50

# Price precision (number of decimal places)
PRICE_PRECISION=4

# Size precision (number of decimal places)
SIZE_PRECISION=4

# ===================================================================
# MARKET MAKING STRATEGY CONFIGURATION
# ===================================================================
# Enable market making strategy (provides liquidity with bid/ask spreads)
MM_ENABLED=false

# Target spread for market making quotes (in basis points)
MM_TARGET_SPREAD_BPS=50

# Maximum position size per market for market making (in USD)
MM_MAX_POSITION_SIZE_USD=100

# Size of each individual quote for market making (in USD)
MM_QUOTE_SIZE_USD=10

# Minimum spread to maintain for market making (in basis points)
MM_MIN_SPREAD_BPS=20

# Maximum spread to quote for market making (in basis points)
MM_MAX_SPREAD_BPS=200

# Inventory skew factor for market making (0.0 = no skew, 1.0 = full skew)
# Higher values increase position size adjustments based on inventory imbalance
MM_INVENTORY_SKEW_FACTOR=0.1

# Edge to add on top of fair value for market making (in basis points)
MM_EDGE_BPS=5

# Minimum market liquidity required for market making (in USD)
MM_MIN_LIQUIDITY=1000

# Comma-separated list of markets to enable for market making
# Leave empty to enable market making on all eligible markets
MM_ENABLED_MARKETS=

# ===================================================================
# SNAPSHOT SERVICE CONFIGURATION
# ===================================================================
# Enable automatic market data snapshots
SNAPSHOT_ENABLED=true

# Interval between market data snapshots in seconds (default: 300 = 5 minutes)
SNAPSHOT_INTERVAL_SECONDS=300

# Number of days to retain market snapshots before cleanup
SNAPSHOT_RETENTION_DAYS=7

# ===================================================================
# HEALTH CHECK CONFIGURATION
# ===================================================================
# Enable health check monitoring
HEALTH_CHECK_ENABLED=true

# Interval between health checks in seconds
HEALTH_CHECK_INTERVAL_SECONDS=60

# ===================================================================
# DEVELOPMENT & TESTING CONFIGURATION
# ===================================================================
# Enable debug mode for additional logging and testing features
DEBUG=false

# Test mode - runs bot in simulation mode without real trades
TEST_MODE=false

# ===================================================================
# SECURITY NOTES
# ===================================================================
# 1. Never commit your actual .env file to version control
# 2. Use strong, unique private keys for production trading
# 3. Consider using environment variable management tools for production
# 4. Regularly rotate API keys and private keys
# 5. Monitor your bot's activity and set up alerts for unusual behavior
# 6. Use separate keys for testing and production environments
# 7. Implement proper key rotation policies
# 8. Use hardware wallets or secure key management for large amounts